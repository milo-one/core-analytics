\name{corek-package}
\alias{corek-package}
\alias{corek}
\docType{package}
\title{Personalized K-Factor Axis for Text Feature Spaces}
\description{
Fits a personalized K-Factor axis in a PCA-transformed text-feature space and
scores new texts by projection, normalized axis position and orthogonal
distance. The package contains method code only; private reference data and
trained axis bundles should be stored outside the package.
}
\keyword{package}
